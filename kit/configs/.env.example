# Diana Starter Kit — env config example
# Copie pra ~/ia-local/.env e edite

# ─── Identidade ─────────────────────────────────────
DIANA_USER_NAME=Seu Nome
DIANA_AGENT_NAME=Diana
DIANA_IDENTITY_DIR=/Users/seu_user/.diana/keys

# ─── LLM ───────────────────────────────────────────
DIANA_FAST_MODEL=qwen3:14b
DIANA_DEEP_MODEL=qwen3:14b
DIANA_LLM_STRATEGY=ollama-only

# Pra ligar MLX nativo (mais rápido em Apple Silicon)
DIANA_MLX_ENABLED=0
DIANA_MLX_MODEL=mlx-community/Qwen3-14B-4bit

# ─── Memória ────────────────────────────────────────
DIANA_MEM0_ENABLED=1

# ─── Network ────────────────────────────────────────
DIANA_CALL_PORT=8600
DIANA_OLLAMA_BASE_URL=http://127.0.0.1:11434
DIANA_OLLAMA_KEEP_ALIVE=10m

# ─── Auto-learning (overnight) ─────────────────────
DIANA_AUTO_PROMOTE=0       # 0 = só treina, não promove (default seguro)
                            # 1 = promove se passar eval gate

# ─── Comportamento ──────────────────────────────────
DIANA_HUMANIZER=1          # ajusta respostas pra PT-BR mais natural
DIANA_PROACTIVITY_MODE=quiet    # quiet | balanced | active
DIANA_NEW_PIPELINE=0       # 1 = answer pipeline com critique (mais lento)
DIANA_THINK=1              # 1 = qwen3 thinking mode ON

# ─── Performance ────────────────────────────────────
DIANA_LLM_EXECUTOR_WORKERS=4

# Customização (avançado)
# DIANA_RERANKER_ENABLED=0
# DIANA_REASONING_MODEL=phi4
# DIANA_INTERNET_ENABLED=0
